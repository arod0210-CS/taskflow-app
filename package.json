{
  "name": "taskflow-app",
  "version": "1.1.0",
  "private": true,
  "description": "A responsive gamified productivity app built with vanilla HTML, CSS, and JavaScript.",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
