    "format:check": "prettier . --check",
    "validate:html": "html-validate index.html",
    "test:a11y": "playwright test tests/a11y.spec.cjs",
    "test:manual-smoke": "node tests/manual-smoke.cjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.54.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.31.0",
    "globals": "^16.3.0",
    "html-validate": "^9.7.1",
    "prettier": "^3.6.2",
    "vitest": "^3.2.4"
  }
}
